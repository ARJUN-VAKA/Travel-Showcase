{
  "name": "travel-showcase",
  "framework": "vite",
  "version": 2,
  "buildCommand": "bash build.sh",
  "outputDirectory": "vercel-dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
